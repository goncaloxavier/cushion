{
  "name": "cushion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite dev",
    "dev:studio": "sanity dev --port 3333",
    "build": "vite build",
    "postbuild": "[ \"$WARM_ON_BUILD\" = true ] && npm run warm:images || true",
    "build:studio": "sanity build",
    "preview": "vite preview",
    "start": "node build",
    "start:studio": "sanity start",
    "check": "svelte-kit sync && tsc --noEmit",
    "lint": "eslint .",
    "test": "npm run e2e",
    "e2e": "playwright test tests/routes.spec.ts tests/sanity-contract.spec.ts",
    "e2e:visual": "playwright test tests/visual.spec.ts",
    "e2e:visual:update": "playwright test tests/visual.spec.ts --update-snapshots",
    "test:e2e": "playwright test tests/routes.spec.ts tests/sanity-contract.spec.ts",
    "test:visual": "playwright test tests/visual.spec.ts",
    "test:visual:update": "playwright test tests/visual.spec.ts --update-snapshots",
    "seed:studio:write": "tsx scripts/write-sanity-seed.ts",
    "seed:studio": "npm run seed:studio:write && sanity datasets import .sanity/seed.ndjson --dataset production --replace",
    "import:cases:write": "tsx scripts/write-case-study-import.ts",
    "import:cases": "npm run import:cases:write && sanity datasets import .sanity/case-study-import.ndjson --dataset production --replace",
    "import:blog:write": "tsx scripts/write-blog-import.ts",
    "import:blog": "npm run import:blog:write && sanity datasets import .sanity/blog-import.ndjson --dataset production --replace",
    "scrape:products": "tsx scripts/scrape-product-images.ts",
    "import:products:write": "tsx scripts/write-product-import.ts",
    "import:products": "npm run import:products:write && sanity datasets import .sanity/product-import.ndjson --dataset production --replace && npm run warm:images",
    "staff:create": "tsx scripts/create-staff.ts",
    "warm:images": "tsx scripts/warm-images.ts",
    "deploy:content": "npm run seed:studio && npm run import:cases && npm run import:blog && npm run import:products",
    "deploy:studio": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "prepare": "svelte-kit sync || true"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@sanity/client": "^7.22.1",
    "@sanity/vision": "^6.0.0",
    "lenis": "^1.3.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^6.0.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "eslint": "^9.28",
    "prettier": "^3.5",
    "svelte": "^5.56.3",
    "typescript": "^5.8",
    "vite": "^7.3.5"
  },
  "prettier": {
    "bracketSpacing": false,
    "printWidth": 100,
    "semi": false,
    "singleQuote": true
  }
}
