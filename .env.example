# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.  `.env` is gitignored, so your
# token never gets committed:   cp .env.example .env
# Restart `npm run dev` (site) and `npx sanity dev` (Studio) after editing.
# ─────────────────────────────────────────────────────────────────────────────

# === Sanity Visual Editing (Presentation / click-to-edit) ===

# A READ token WITH DRAFT ACCESS. Create it at:
#   https://sanity.io/manage  →  project "u4uyfix8"  →  API  →  Tokens  →  Add token
#   Name it e.g. "Visual Editing Viewer", Permissions: Viewer.  Copy it here.
SANITY_VIEWER_TOKEN=

# The running website origin the Studio embeds for the preview iframe.
#   Local dev:  http://localhost:5173      Production:  https://your-deployed-site
SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:5173

# The Studio URL used for stega click-to-edit deep links (workspace basePath is /website).
#   Local dev:  http://localhost:3333/website   Deployed: https://<your-studio>.sanity.studio/website
SANITY_STUDIO_URL=http://localhost:3333/website
